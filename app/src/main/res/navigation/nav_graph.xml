<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/noteFragment">

    <fragment
        android:id="@+id/noteFragment"
        android:name="com.example.notex.fragments.NoteFragment"
        android:label="fragment_note"
        tools:layout="@layout/fragment_note">

        <action
            android:id="@+id/action_noteFragment_to_saveOrUpdate"
            app:destination="@id/saveOrUpdate" />
    </fragment>

    <fragment
        android:id="@+id/saveOrUpdate"
        android:name="com.example.notex.fragments.SaveOrDeleteFragments"
        android:label="fragment_save_or_update"
        tools:layout="@layout/fragment_save_or_delete">

        <argument
            android:name="note"
            app:argType="com.example.notex.model.Note"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

</navigation>